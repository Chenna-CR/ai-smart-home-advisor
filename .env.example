# AI Smart Home Advisor - Production Configuration

# =======================================================
# REQUIRED: Groq AI API Key
# =======================================================
# Get your free API key from https://console.groq.com
# Used for Llama3-8b-8192 model to analyze user intent
GROQ_API_KEY=your_key

# =======================================================
# REQUIRED: SerpAPI Key for Google Shopping
# =======================================================
# Get your free API key from https://serpapi.com
# Free tier: 100 queries/month
SERPAPI_KEY=37690a049a781e0d398c2d4c714a3dce40103ea4bb1b240dbd03db2db589d7e0

# =======================================================
# OPTIONAL: Configuration
# =======================================================
# Search mode (currently only "google" supported)
SEARCH_MODE=google

# Request timeout in seconds (default: 10)
REQUEST_TIMEOUT=10

# Groq API endpoint override (optional)
# GROQ_API_URL=https://api.groq.com/openai/v1/chat/completions

